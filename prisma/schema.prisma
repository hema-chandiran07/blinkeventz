generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS (GLOBAL)
//////////////////////////////////////////////////////

enum Role {
  CUSTOMER
  VENDOR
  VENUE_OWNER
  ADMIN
  EVENT_MANAGER
  SUPPORT
}

enum VendorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ServiceType {
  CATERING
  DECOR
  PHOTOGRAPHY
  MAKEUP
  DJ
  MUSIC
  CAR_RENTAL
  PRIEST
  OTHER
}

enum VendorPricingModel {
  PER_EVENT
  PER_PERSON
  PER_DAY
  PACKAGE
}

enum CartStatus {
  ACTIVE
  LOCKED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ItemType {
  VENUE
  VENDOR_SERVICE
  ADDON
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
}

enum ExpressPlanType {
  FIXED
  CUSTOMIZED
}

enum ExpressStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

enum VenueType {
  HALL
  MANDAPAM
  LAWN
  RESORT
  BANQUET
}

enum VenueStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
  DELISTED
}

enum EntityType {
  VENUE
  VENDOR
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  HOLD
}

enum KycDocType {
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum AIPlanStatus {
  GENERATED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EventStatus {
  INQUIRY
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ItemTypeForEvent {
  VENUE
  VENDOR_SERVICE
  ADDON
}

enum EventServiceStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  VENDOR_APPROVED
  VENDOR_REJECTED
  VENUE_APPROVED
  VENUE_REJECTED
  SERVICE_APPROVED
  SERVICE_REJECTED
  EVENT_REMINDER
  EVENT_CANCELLED
  SYSTEM_ALERT
  OTHER
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  PENDING // created, not processed
  PROCESSING // picked by queue
  SENT // at least one delivery sent
  PARTIAL // some channels failed
  FAILED // all channels failed
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////
model User {
  id    Int     @id @default(autoincrement())
  name  String
  email String? @unique
  phone String? @unique

  passwordHash String? // 👈 make OPTIONAL
  googleId     String? @unique

  role                    Role                     @default(CUSTOMER)
  isActive                Boolean                  @default(true)
  //profiles
  customerProfile         CustomerProfile?
  vendor                  Vendor?
  //Relations
  customerEvents          Event[]                  @relation("CustomerEvents")
  managedEvents           Event[]                  @relation("ManagedEvents")
  venues                  Venue[]
  bookings                Booking[]
  payments                Payment[]
  Cart                    Cart[]
  KycDocument             KycDocument[]
  bankAccounts            BankAccount[]
  Event                   Event[]
  //auditLogs AuditLog[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  AIPlan                  AIPlan[]
  ExpressRequest          ExpressRequest[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
}

model CustomerProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  preferredCity String?
  notes         String?
}

//////////////////////////////////////////////////////
// VENDOR 
//////////////////////////////////////////////////////

model Vendor {
  id                 Int                      @id @default(autoincrement())
  userId             Int                      @unique
  businessName       String
  description        String?
  city               String
  area               String
  serviceRadiusKm    Int?
  verificationStatus VendorVerificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  services VendorService[]
}

//////////////////////////////////////////////////////
// VENDOR SERVICE
//////////////////////////////////////////////////////
model VendorService {
  id       Int @id @default(autoincrement())
  vendorId Int

  name         String
  serviceType  ServiceType
  pricingModel VendorPricingModel
  baseRate     Int

  minGuests Int?
  maxGuests Int?

  description String?
  inclusions  String?
  exclusions  String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  cartItems    CartItem[]
  EventService EventService[]

  @@index([vendorId])
}

//////////////////////////////////////////////////////
// VENUE & AVAILABILITY
//////////////////////////////////////////////////////

model Venue {
  id Int @id @default(autoincrement())

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  name        String
  type        VenueType
  description String?
  address     String
  city        String
  area        String
  pincode     String

  capacityMin Int
  capacityMax Int

  basePriceMorning Int?
  basePriceEvening Int?
  basePriceFullDay Int?

  amenities String?
  policies  String?

  status VenueStatus @default(PENDING_APPROVAL)

  photos       VenuePhoto[]
  availability AvailabilitySlot[]
  events       Event[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  EventService EventService[]
}

model VenuePhoto {
  id      Int   @id @default(autoincrement())
  venueId Int
  venue   Venue @relation(fields: [venueId], references: [id])

  url     String
  isCover Boolean @default(false)

  createdAt DateTime @default(now())
}

model AvailabilitySlot {
  id Int @id @default(autoincrement())

  entityType EntityType
  entityId   Int

  date     DateTime
  timeSlot String // MORNING / EVENING / FULL_DAY
  status   SlotStatus @default(AVAILABLE)

  venue     Venue?    @relation(fields: [entityId], references: [id])
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([entityType, entityId, date, timeSlot])
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    Int
  slotId    Int
  createdAt DateTime @default(now())

  user User             @relation(fields: [userId], references: [id])
  slot AvailabilitySlot @relation(fields: [slotId], references: [id])
}

//////////////////////////////////////////////////////
// CART
//////////////////////////////////////////////////////

model Cart {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id])
  userId    Int
  status    CartStatus @default(ACTIVE)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Payment   Payment[]
}

model CartItem {
  id     Int  @id @default(autoincrement())
  cart   Cart @relation(fields: [cartId], references: [id])
  cartId Int

  itemType ItemType

  venueId         Int?
  vendorServiceId Int?
  addonId         Int?

  vendorService VendorService? @relation(fields: [vendorServiceId], references: [id])

  date       DateTime?
  timeSlot   String?
  quantity   Int       @default(1)
  unitPrice  Int
  totalPrice Int
  meta       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([vendorServiceId])
}

//////////////////////////////////////////////////////
// AI PLAN
//////////////////////////////////////////////////////

model AIPlan {
  id      Int  @id @default(autoincrement())
  userId  Int
  EventId Int?

  budget     Int
  city       String
  area       String
  guestCount Int

  planJson Json
  status   AIPlanStatus @default(GENERATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  Event Event? @relation(fields: [EventId], references: [id])

  @@index([userId])
  @@index([EventId])
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

model Payment {
  id                Int             @id @default(autoincrement())
  userId            Int
  cartId            Int
  provider          PaymentProvider
  providerOrderId   String          @unique
  providerPaymentId String?
  signature         String?
  amount            Int
  currency          String          @default("INR")
  status            PaymentStatus

  user User @relation(fields: [userId], references: [id])
  cart Cart @relation(fields: [cartId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Event     Event?   @relation(fields: [eventId], references: [id])
  eventId   Int?

  @@index([cartId])
}

//////////////////////////////////////////////////////
// EXPRESS
//////////////////////////////////////////////////////
model ExpressRequest {
  id         Int             @id @default(autoincrement())
  userId     Int
  EventId    Int             @unique
  planType   ExpressPlanType
  status     ExpressStatus   @default(PENDING)
  startedAt  DateTime
  expiresAt  DateTime
  expressFee Int // paise
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  Event Event @relation(fields: [EventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////////////////////////////////////
// KYC
//////////////////////////////////////////////////////

model KycDocument {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  docType    KycDocType
  docNumber  String // 🔐 encrypted at app layer
  docFileUrl String

  status     KycStatus @default(PENDING)
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BankAccount {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountHolder String
  accountNumber String
  ifsc          String
  bankName      String
  branchName    String?

  referenceId String  @unique
  isVerified  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

////////////////////////////////////
///Event & EventServices
///////////////////////////////////
model Event {
  id Int @id @default(autoincrement())

  customer   User @relation("CustomerEvents", fields: [customerId], references: [id])
  customerId Int

  assignedManager   User? @relation("ManagedEvents", fields: [assignedManagerId], references: [id])
  assignedManagerId Int?

  eventType String
  title     String?
  date      DateTime
  timeSlot  String // MORNING | EVENING | FULL_DAY
  city      String
  area      String?

  venue   Venue? @relation(fields: [venueId], references: [id])
  venueId Int?

  guestCount Int
  status     EventStatus @default(CONFIRMED)
  isExpress  Boolean     @default(false)

  expressRequest ExpressRequest?

  // Pricing
  subtotal    Int
  discount    Int @default(0)
  platformFee Int @default(0)
  tax         Int @default(0)
  totalAmount Int

  services      EventService[]
  payments      Payment[]
  notifications Notification[]
  //auditLogs          AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  AIPlan    AIPlan[]
}

model EventService {
  id Int @id @default(autoincrement())

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int

  itemType ItemTypeForEvent

  venue   Venue? @relation(fields: [venueId], references: [id])
  venueId Int?

  vendorService   VendorService? @relation(fields: [vendorServiceId], references: [id])
  vendorServiceId Int?

  addonId Int?

  serviceType ServiceType?
  finalPrice  Int
  notes       String?
  status      EventServiceStatus @default(CONFIRMED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// Notifications
//////////////////////////////////////////////////////

model Notification {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  eventId Int?
  event   Event? @relation(fields: [eventId], references: [id])

  type     NotificationType
  priority NotificationPriority @default(NORMAL)

  title    String
  message  String
  metadata Json?

  read   Boolean   @default(false)
  readAt DateTime?

  status NotificationStatus @default(PENDING)

  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  NotificationDelivery NotificationDelivery[]

  @@index([userId, read])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model NotificationDelivery {
  id Int @id @default(autoincrement())

  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  channel  NotificationChannel
  provider String? // SendGrid, Twilio, Firebase, etc

  status      DeliveryStatus @default(PENDING)
  attempts    Int            @default(0)
  maxAttempts Int            @default(3)

  providerRef  String?
  errorMessage String?

  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel, status])
}

model NotificationPreference {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  type    NotificationType
  channel NotificationChannel

  enabled Boolean @default(true)

  @@unique([userId, type, channel])
}
