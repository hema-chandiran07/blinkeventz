generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER (TEMP – will be expanded later)
//////////////////////////////////////////////////////
model User {
  id     Int     @id @default(autoincrement())
  vendor Vendor?
  Cart   Cart[]
}

//////////////////////////////////////////////////////
// VENDOR
//////////////////////////////////////////////////////
model Vendor {
  id                 Int                      @id @default(autoincrement())
  userId             Int                      @unique
  businessName       String
  description        String?
  city               String
  area               String
  serviceRadiusKm    Int?
  verificationStatus VendorVerificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  services VendorService[]
}

//////////////////////////////////////////////////////
// VENDOR SERVICE
//////////////////////////////////////////////////////
model VendorService {
  id       Int @id @default(autoincrement())
  vendorId Int

  name         String
  serviceType  ServiceType
  pricingModel VendorPricingModel
  baseRate     Int

  minGuests Int?
  maxGuests Int?

  description String?
  inclusions  String?
  exclusions  String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor    Vendor     @relation(fields: [vendorId], references: [id])
  cartItems CartItem[]

  @@index([vendorId])
}

//////////////////////////////////////////////////////////////////
//CART 
/////////////////////////////////////////////////////////////////

model Cart {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id])
  userId    Int
  status    CartStatus @default(ACTIVE)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

//////////////////////////////////////////////////////////////////
//CART ITEM
/////////////////////////////////////////////////////////////////

model CartItem {
  id     Int  @id @default(autoincrement())
  cart   Cart @relation(fields: [cartId], references: [id])
  cartId Int

  itemType ItemType

  venueId         Int?
  vendorServiceId Int?
  addonId         Int?

  vendorService VendorService? @relation(fields: [vendorServiceId], references: [id])

  date       DateTime?
  timeSlot   String?
  quantity   Int       @default(1)
  unitPrice  Int
  totalPrice Int
  meta       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([vendorServiceId])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////
enum VendorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ServiceType {
  CATERING
  DECOR
  PHOTOGRAPHY
  MAKEUP
  DJ
  MUSIC
  CAR_RENTAL
  PRIEST
  OTHER
}

enum VendorPricingModel {
  PER_EVENT
  PER_PERSON
  PER_DAY
  PACKAGE
}

enum CartStatus {
  ACTIVE
  LOCKED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ItemType {
  VENUE
  VENDOR_SERVICE
  ADDON
}
