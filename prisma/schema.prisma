generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  VENUE_OWNER
  ADMIN
  EVENT_MANAGER
  SUPPORT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?  @unique
  passwordHash String
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)

  // Profiles
  customerProfile CustomerProfile?
  //vendor          Vendor?

  // Relations
  venues        Venue[]
  bookings      Booking[]
  //payments      Payment[]
  //notifications Notification[]
  //auditLogs     AuditLog[]
   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerProfile {
  id       Int  @id @default(autoincrement())
  userId   Int  @unique
  user     User @relation(fields: [userId], references: [id])

  preferredCity String?
  notes         String?
}

enum VenueType {
  HALL
  MANDAPAM
  LAWN
  RESORT
  BANQUET
}

enum VenueStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
  DELISTED
}

model Venue {
  id        Int @id @default(autoincrement())

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  name        String
  type        VenueType
  description String?
  address     String
  city        String
  area        String
  pincode     String

  capacityMin Int
  capacityMax Int

  basePriceMorning Int?
  basePriceEvening Int?
  basePriceFullDay Int?

  amenities String?
  policies  String?

  status VenueStatus @default(PENDING_APPROVAL)

  photos       VenuePhoto[]
  availability AvailabilitySlot[]
  //events       Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model VenuePhoto {
  id      Int @id @default(autoincrement())
  venueId Int
  venue   Venue @relation(fields: [venueId], references: [id])

  url     String
  isCover Boolean @default(false)

  createdAt DateTime @default(now())
}

enum EntityType {
  VENUE
  VENDOR
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  HOLD
}

model AvailabilitySlot {
  id        Int @id @default(autoincrement())

  entityType EntityType
  entityId   Int

  date     DateTime
  timeSlot String // MORNING / EVENING / FULL_DAY
  status   SlotStatus @default(AVAILABLE)

  venue Venue? @relation(fields: [entityId], references: [id])
  bookings Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId, date, timeSlot])
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    Int
  slotId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  slot AvailabilitySlot @relation(fields: [slotId], references: [id])
}

model KycDocument {
  id         Int        @id @default(autoincrement())

  userId     Int
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  docType    KycDocType
  docNumber  String     // ENCRYPTED at application level
  docFileUrl String     // S3 / Cloudinary URL

  status     KycStatus  @default(PENDING)
  verifiedAt DateTime?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@unique([userId, docType]) // One document type per user
}

enum KycDocType {
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}


