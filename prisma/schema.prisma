generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USER (TEMP – will be expanded later)
//////////////////////////////////////////////////////
model User {
  id     Int     @id @default(autoincrement())
  vendor Vendor?
  Cart   Cart[]
}

//////////////////////////////////////////////////////
// VENDOR
//////////////////////////////////////////////////////
model Vendor {
  id                 Int                      @id @default(autoincrement())
  userId             Int                      @unique
  businessName       String
  description        String?
  city               String
  area               String
  serviceRadiusKm    Int?
  verificationStatus VendorVerificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  services VendorService[]
}

//////////////////////////////////////////////////////
// VENDOR SERVICE
//////////////////////////////////////////////////////
model VendorService {
  id       Int @id @default(autoincrement())
  vendorId Int

  name         String
  serviceType  ServiceType
  pricingModel VendorPricingModel
  baseRate     Int

  minGuests Int?
  maxGuests Int?

  description String?
  inclusions  String?
  exclusions  String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor    Vendor     @relation(fields: [vendorId], references: [id])
  cartItems CartItem[]

  @@index([vendorId])
}

//////////////////////////////////////////////////////////////////
//CART 
/////////////////////////////////////////////////////////////////

model Cart {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id])
  userId    Int
  status    CartStatus @default(ACTIVE)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

//////////////////////////////////////////////////////////////////
//CART ITEM
/////////////////////////////////////////////////////////////////

model CartItem {
  id     Int  @id @default(autoincrement())
  cart   Cart @relation(fields: [cartId], references: [id])
  cartId Int

  itemType ItemType

  venueId         Int?
  vendorServiceId Int?
  addonId         Int?

  vendorService VendorService? @relation(fields: [vendorServiceId], references: [id])

  date       DateTime?
  timeSlot   String?
  quantity   Int       @default(1)
  unitPrice  Int
  totalPrice Int
  meta       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([vendorServiceId])
}

//////////////////////////////////////////////////////////////////
//PAYMENTS
/////////////////////////////////////////////////////////////////
model Payment {
  id                Int             @id @default(autoincrement())
  userId            Int
  cartId            Int
  provider          PaymentProvider
  providerOrderId   String          @unique
  providerPaymentId String?
  signature         String?
  amount            Int
  currency          String          @default("INR")
  status            PaymentStatus
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([cartId])
}

//////////////////////////////////////////////////////
// TEMP EVENT (DEV-B TEMPORARY)
//////////////////////////////////////////////////////
model TempEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventDate DateTime
  city      String
  area      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expressRequest ExpressRequest?
}

//////////////////////////////////////////////////////
// ExpresssRequest
//////////////////////////////////////////////////////
model ExpressRequest {
  id          Int             @id @default(autoincrement())
  tempEventId Int             @unique
  planType    ExpressPlanType
  status      ExpressStatus   @default(PENDING)
  startedAt   DateTime
  expiresAt   DateTime
  expressFee  Int // paise
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tempEvent TempEvent @relation(fields: [tempEventId], references: [id])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////
enum VendorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ServiceType {
  CATERING
  DECOR
  PHOTOGRAPHY
  MAKEUP
  DJ
  MUSIC
  CAR_RENTAL
  PRIEST
  OTHER
}

enum VendorPricingModel {
  PER_EVENT
  PER_PERSON
  PER_DAY
  PACKAGE
}

enum CartStatus {
  ACTIVE
  LOCKED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ItemType {
  VENUE
  VENDOR_SERVICE
  ADDON
}

enum PaymentStatus {
  PENDING // order created, not paid
  AUTHORIZED // payment authorized
  SUCCESS // payment captured
  FAILED // payment failed
  REFUNDED // refunded
}

enum PaymentProvider {
  RAZORPAY
}

enum ExpressPlanType {
  FIXED
  CUSTOMIZED
}

enum ExpressStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}
