generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  googleId     String?  @unique
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  image        String? // Base64 profile picture
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Password reset security
  passwordResetToken  String? // Hashed token - never expose
  passwordResetExpiry DateTime?

  // OAuth
  facebookId      String? @unique
  isEmailVerified Boolean @default(false)

  // Account lockout security
  lockedUntil DateTime?

  // Relations
  AIPlan                  AIPlan[]
  AIConversation          AIConversation[]
  bankAccounts            BankAccount[]
  bookings                Booking[]
  Cart                    Cart[]
  customerProfile         CustomerProfile?
  managedEvents           Event[]                  @relation("ManagedEvents")
  customerEvents          Event[]                  @relation("CustomerEvents")
  Event                   Event[]
  ExpressRequest          ExpressRequest[]
  KycDocument             KycDocument[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  payments                Payment[]
  reviews                 Review[]
  reviewVotes             ReviewVote[]
  vendor                  Vendor?
  venues                  Venue[]
  refreshTokens           RefreshToken[]
  searchAudits            SearchAudit[]

  // Indexes for authentication queries
  @@index([email])
  @@index([googleId])
  @@index([facebookId])
  @@index([passwordResetToken])
}

/// Search Audit Model - Track query performance and intent
model SearchAudit {
  id           Int      @id @default(autoincrement())
  userId       Int?
  query        String
  filters      Json?
  resultsCount Int
  durationMs   Int
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([query])
}

/// Refresh Token Model for JWT refresh mechanism
model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  token      String // Hashed token for security
  expiresAt  DateTime
  revoked    Boolean   @default(false)
  revokedAt  DateTime?
  deviceInfo String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model CustomerProfile {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  preferredCity String?
  notes         String?
  user          User    @relation(fields: [userId], references: [id])
}

model Vendor {
  id                 Int                      @id @default(autoincrement())
  userId             Int                      @unique
  businessName       String
  ownerName          String?
  email              String?
  phone              String?
  businessType       String? // PHOTOGRAPHY, CATERING, DECOR, DJ, MAKEUP, VIDEOGRAPHY, ENTERTAINMENT, OTHER
  description        String?
  serviceCategory    String?
  city               String
  area               String
  serviceRadiusKm    Int?
  basePrice          Int?
  pricingModel       String?
  experience         Int?
  verified           Boolean                  @default(false)
  verificationStatus VendorVerificationStatus @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  username           String?                  @unique
  rejectionReason    String?

  // Business Images
  businessImages String[] @default([])
  images         String[] @default([])

  // KYC Documents
  kycDocType   String? // AADHAAR, PAN, PASSPORT, DRIVING_LICENSE
  kycDocNumber String?
  kycDocFiles  String[] @default([])

  // FSSAI License (CONDITIONAL - only for CATERING)
  foodLicenseFiles String[] @default([])

  payouts           Payout[]
  reviews           Review[]
  user              User               @relation(fields: [userId], references: [id])
  services          VendorService[]
  portfolioImages   PortfolioImage[]
  availabilitySlots AvailabilitySlot[] @relation("VendorAvailability")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model VendorService {
  id           Int                @id @default(autoincrement())
  vendorId     Int
  name         String
  serviceType  ServiceType
  pricingModel VendorPricingModel
  baseRate     Int
  minGuests    Int?
  maxGuests    Int?
  description  String?
  inclusions   String?
  exclusions   String?
  images       String[]           @default([])
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  cartItems    CartItem[]
  EventService EventService[]
  events       Event[]            // Bidirectional relation with Event model
  vendor       Vendor             @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

model Venue {
  id               Int         @id @default(autoincrement())
  ownerId          Int
  name             String
  type             VenueType
  description      String?
  address          String
  city             String
  area             String
  pincode          String
  capacityMin      Int
  capacityMax      Int
  basePriceMorning Int?
  basePriceEvening Int?
  basePriceFullDay Int?
  amenities        String?
  policies         String?
  status           VenueStatus @default(PENDING_APPROVAL)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  username         String?     @unique
  rejectionReason  String?

  // Venue Images (main photos)
  venueImages String[] @default([])

  // KYC Documents
  kycDocType   String? // AADHAAR, PAN, PASSPORT, DRIVING_LICENSE
  kycDocNumber String?
  kycDocFiles  String[] @default([])

  // Trade License (MANDATORY for venues)
  venueGovtCertificateFiles String[] @default([])

  // Note: AvailabilitySlot references are polymorphic (entityType + entityId)
  // Queried at application layer, not via Prisma relation
  availabilitySlots AvailabilitySlot[] @relation("VenueAvailability")
  cartItems         CartItem[]
  events            Event[]
  EventService      EventService[]
  payouts           Payout[]
  reviews           Review[]
  owner             User               @relation(fields: [ownerId], references: [id])
  photos            VenuePhoto[]

  // ============================================
  // DATABASE INDEXES FOR PERFORMANCE
  // ============================================
  @@index([city])
  @@index([area])
  @@index([status])
  @@index([ownerId])
  @@index([city, status])
  @@index([type, status])
  @@index([createdAt(sort: Desc)])
}

/// Venue Photo - Advanced Portfolio Management
model VenuePhoto {
  id          Int           @id @default(autoincrement())
  venueId     Int
  url         String
  title       String? // Descriptive title for SEO and accessibility
  description String? // Alt text and description
  category    PhotoCategory @default(GALLERY) // GALLERY, MAIN, CERTIFICATE, BEHIND_SCENES
  order       Int           @default(0) // Display order (lower = first)
  isCover     Boolean       @default(false)
  isFeatured  Boolean       @default(false) // Show on home page featured section
  quality     ImageQuality  @default(HD) // HD, MEDIUM, THUMBNAIL
  tags        String[]      @default([]) // Searchable tags
  isActive    Boolean       @default(true) // Soft delete support
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  venue       Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([category])
  @@index([order])
  @@index([isCover])
  @@index([isFeatured])
  @@index([isActive])
}

/// Vendor Portfolio Image - Advanced Portfolio Management  
model PortfolioImage {
  id          Int           @id @default(autoincrement())
  vendorId    Int
  imageUrl    String
  title       String? // Descriptive title for SEO and accessibility
  description String? // Alt text and description
  category    PhotoCategory @default(GALLERY) // GALLERY, MAIN, CERTIFICATE, BEHIND_SCENES, WORK_SAMPLE
  order       Int           @default(0) // Display order (lower = first)
  isCover     Boolean       @default(false) // Main profile image
  isFeatured  Boolean       @default(false) // Show on home page featured section
  quality     ImageQuality  @default(HD) // HD, MEDIUM, THUMBNAIL
  tags        String[]      @default([]) // Searchable tags (e.g., "wedding", "corporate")
  isActive    Boolean       @default(true) // Soft delete support
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  vendor      Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([category])
  @@index([order])
  @@index([isCover])
  @@index([isFeatured])
  @@index([isActive])
}

/// Photo/Image Category for classification
enum PhotoCategory {
  GALLERY // General gallery images
  MAIN // Main/hero image
  CERTIFICATE // Certificates, licenses, KYC docs
  BEHIND_SCENES // Behind the scenes, setup process
  WORK_SAMPLE // Portfolio work samples (vendor only)
  WEDDING // Wedding events
  ENGAGEMENT // Engagement events
  RECEPTION // Reception events
  PREWEDDING // Pre-wedding events
  CORPORATE // Corporate events
  BIRTHDAY // Birthday events
  OTHER // Other events
}

/// Image Quality/Size Classification
enum ImageQuality {
  HD // High definition (full resolution)
  MEDIUM // Medium resolution (web optimized)
  THUMBNAIL // Thumbnail (small preview)
}

model AvailabilitySlot {
  id         Int        @id @default(autoincrement())
  entityType EntityType
  date       DateTime
  timeSlot   String
  status     SlotStatus @default(AVAILABLE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  bookings   Booking[]

  // Separate FK columns — avoids PG dual-FK conflict on same column
  venueId  Int?
  venue    Venue?  @relation("VenueAvailability", fields: [venueId], references: [id], onDelete: Cascade)
  vendorId Int?
  vendor   Vendor? @relation("VendorAvailability", fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([vendorId])
  @@index([entityType, date, timeSlot])
}

model Booking {
  id          Int              @id @default(autoincrement())
  userId      Int
  slotId      Int
  status      BookingStatus    @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  completedAt DateTime?
  slot        AvailabilitySlot @relation(fields: [slotId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([slotId])
  @@index([status])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int
  status    CartStatus @default(ACTIVE)
  isExpress Boolean   @default(false)
  expressFee Int      @default(0)
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  Payment   Payment[]

  @@index([userId])
  @@index([status])
}

model CartItem {
  id              Int            @id @default(autoincrement())
  cartId          Int
  itemType        ItemType
  venueId         Int?
  vendorServiceId Int?
  addonId         Int?
  date            DateTime?
  timeSlot        String?
  quantity        Int            @default(1)
  unitPrice       Decimal        @db.Decimal(10, 2) // Server-calculated only
  totalPrice      Decimal        @db.Decimal(10, 2) // Server-calculated only
  meta            Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cart            Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  vendorService   VendorService? @relation(fields: [vendorServiceId], references: [id])
  venue           Venue?         @relation(fields: [venueId], references: [id])

  @@index([cartId])
  @@index([vendorServiceId])
  @@index([venueId])
}

model AIPlan {
  id            Int              @id @default(autoincrement())
  userId        Int
  EventId       Int?
  budget        Int
  city          String
  area          String
  guestCount    Int
  planJson      Json
  status        AIPlanStatus     @default(GENERATED)
  shareId       String           @unique @default(uuid()) // For public sharing
  isPublic      Boolean          @default(false) // Enable/disable sharing
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  Event         Event?           @relation(fields: [EventId], references: [id])
  user          User             @relation(fields: [userId], references: [id])
  conversations AIConversation[]

  @@index([userId])
  @@index([EventId])
}

/// AI Chatbot Conversation
model AIConversation {
  id            String               @id @default(uuid())
  userId        Int
  state         Json
  status        AIConversationStatus @default(COLLECTING)
  planId        Int?
  generationKey String?              @unique // For idempotency
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan AIPlan? @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([status])
}

model Payment {
  id                     Int             @id @default(autoincrement())
  userId                 Int
  cartId                 Int? // Optional for direct bookings (no cart)
  provider               PaymentProvider
  providerOrderId        String          @unique // Razorpay order ID
  providerPaymentId      String? // Razorpay payment ID
  providerWebhookEventId String?         @unique // Razorpay webhook event ID - for deduplication
  signature              String? // Payment signature (for verification)
  amount                 Int // Amount in paise
  currency               String          @default("INR")
  status                 PaymentStatus

  // Idempotency
  idempotencyKey String? @unique // Client-provided idempotency key

  // Metadata
  metadata Json? // Additional payment metadata
  notes    String? // Internal notes

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime? // Payment expiry time
  completedAt DateTime? // When payment was completed

  // Relations
  eventId Int?
  cart    Cart?  @relation(fields: [cartId], references: [id])
  event   Event? @relation(fields: [eventId], references: [id])
  user    User   @relation(fields: [userId], references: [id])

  // Audit trail
  paymentEvents PaymentEvent[]

  @@index([userId])
  @@index([cartId])
  @@index([status])
  @@index([providerOrderId])
  @@index([createdAt])
  @@index([expiresAt])
}

// Payment Event Audit Trail - tracks all state changes
model PaymentEvent {
  id              Int           @id @default(autoincrement())
  paymentId       Int
  eventType       String // e.g., 'payment.created', 'payment.captured', 'payment.failed'
  status          PaymentStatus // Status after this event
  providerEventId String? // Razorpay event ID

  // Event data
  requestId String? // Internal request ID for tracing
  ipAddress String? // Client IP
  userAgent String? // Client user agent

  // Raw data
  payload  Json? // Raw webhook payload
  response Json? // Response sent

  // Error handling
  errorMessage String?
  retryCount   Int     @default(0)

  // Timestamps
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  // Relation
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([eventType])
  @@index([providerEventId])
  @@index([createdAt])
}

model Payout {
  id              Int          @id @default(autoincrement())
  vendorId        Int?
  venueId         Int?
  eventId         Int?
  amount          Int
  status          PayoutStatus @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  event           Event?       @relation(fields: [eventId], references: [id])
  vendor          Vendor?      @relation(fields: [vendorId], references: [id])
  venue           Venue?       @relation(fields: [venueId], references: [id])

  @@index([vendorId])
  @@index([venueId])
  @@index([status])
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model ExpressRequest {
  id              Int             @id @default(autoincrement())
  userId          Int
  EventId         Int             @unique
  planType        ExpressPlanType
  status          ExpressStatus   @default(PENDING)
  startedAt       DateTime
  expiresAt       DateTime
  expressFee      Int
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  Event           Event           @relation(fields: [EventId], references: [id])
  user            User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

model KycDocument {
  id              Int        @id @default(autoincrement())
  userId          Int
  docType         KycDocType
  docNumber       String
  docFileUrl      String
  status          KycStatus  @default(PENDING)
  verifiedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  docNumberHash   String
  rejectionReason String?
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([docType, docNumberHash], map: "unique_doc_per_type")
  @@index([userId])
  @@index([status])
  @@index([docNumberHash])
}

model BankAccount {
  id                Int      @id @default(autoincrement())
  userId            Int
  accountHolder     String
  accountNumber     String
  ifsc              String
  bankName          String
  branchName        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  isVerified        Boolean  @default(false)
  referenceId       String   @unique
  accountNumberHash String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isVerified])
}

model BankWebhookLog {
  id          Int      @id @default(autoincrement())
  referenceId String
  payload     Json
  status      String
  createdAt   DateTime @default(now())

  @@index([referenceId])
}

/// /////////////////////////////////
/// Event & EventServices
/// ////////////////////////////////
model Event {
  id                Int             @id @default(autoincrement())
  customerId        Int             @default(0)
  assignedManagerId Int?
  eventType         String          @default("BOOKING")
  title             String?
  date              DateTime
  timeSlot          String
  city              String          @default("Chennai")
  area              String?
  venueId           Int?
  vendorServiceId   Int?
  guestCount        Int             @default(1)
  status            EventStatus     @default(PENDING_PAYMENT)
  isExpress         Boolean         @default(false)
  expressFee        Int             @default(0)
  subtotal          Int             @default(0)
  discount          Int             @default(0)
  platformFee       Int             @default(0)
  tax               Int             @default(0)
  totalAmount       Int             @default(0)
  meta              Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  userId            Int?
  promotionId       Int?
  AIPlan            AIPlan[]
  assignedManager   User?           @relation("ManagedEvents", fields: [assignedManagerId], references: [id])
  customer          User            @relation("CustomerEvents", fields: [customerId], references: [id])
  promotion         Promotion?      @relation(fields: [promotionId], references: [id])
  User              User?           @relation(fields: [userId], references: [id])
  venue             Venue?          @relation(fields: [venueId], references: [id])
  vendorService     VendorService?  @relation(fields: [vendorServiceId], references: [id])
  services          EventService[]
  expressRequest    ExpressRequest?
  notifications     Notification[]
  payments          Payment[]
  payouts           Payout[]
  reviews           Review[]

  // ============================================
  // DATABASE INDEXES FOR PERFORMANCE
  // ============================================
  @@index([customerId])
  @@index([assignedManagerId])
  @@index([venueId])
  @@index([date])
  @@index([city])
  @@index([status])
  @@index([isExpress])
  @@index([createdAt(sort: Desc)])
  @@index([date, status])
  @@index([city, date])
  @@index([customerId, status])
}

model Promotion {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Int
  minCartValue  Int?
  maxDiscount   Int?
  validFrom     DateTime
  validUntil    DateTime
  usageLimit    Int?
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        Event[]

  @@index([code])
  @@index([isActive])
}

model Review {
  id          Int          @id @default(autoincrement())
  userId      Int
  venueId     Int?
  vendorId    Int?
  eventId     Int?
  rating      Int
  title       String?
  comment     String?
  response    String?
  respondedAt DateTime?
  status      ReviewStatus @default(PENDING)
  helpful     Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  event       Event?       @relation(fields: [eventId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  vendor      Vendor?      @relation(fields: [vendorId], references: [id])
  venue       Venue?       @relation(fields: [venueId], references: [id])
  votes       ReviewVote[]

  @@index([venueId])
  @@index([vendorId])
  @@index([status])
}

model ReviewVote {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  userId    Int
  helpful   Boolean
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([reviewId, userId])
}

model EventService {
  id              Int                @id @default(autoincrement())
  eventId         Int
  itemType        ItemTypeForEvent
  venueId         Int?
  vendorServiceId Int?
  addonId         Int?
  serviceType     ServiceType?
  finalPrice      Int
  notes           String?
  status          EventServiceStatus @default(CONFIRMED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  event           Event              @relation(fields: [eventId], references: [id])
  vendorService   VendorService?     @relation(fields: [vendorServiceId], references: [id])
  venue           Venue?             @relation(fields: [venueId], references: [id])

  // ============================================
  // DATABASE INDEXES FOR PERFORMANCE
  // ============================================
  @@index([eventId])
  @@index([venueId])
  @@index([vendorServiceId])
  @@index([itemType])
  @@index([status])
}

model Notification {
  id                   Int                    @id @default(autoincrement())
  userId               Int
  eventId              Int?
  type                 NotificationType
  priority             NotificationPriority   @default(NORMAL)
  title                String
  message              String
  metadata             Json?
  read                 Boolean                @default(false)
  readAt               DateTime?
  status               NotificationStatus     @default(PENDING)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  event                Event?                 @relation(fields: [eventId], references: [id])
  user                 User                   @relation(fields: [userId], references: [id])
  NotificationDelivery NotificationDelivery[]

  @@index([userId, read])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model NotificationDelivery {
  id             Int                 @id @default(autoincrement())
  notificationId Int
  channel        NotificationChannel
  provider       String?
  status         DeliveryStatus      @default(PENDING)
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  providerRef    String?
  errorMessage   String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([channel, status])
}

model NotificationPreference {
  id      Int                 @id @default(autoincrement())
  userId  Int
  type    NotificationType
  channel NotificationChannel
  enabled Boolean             @default(true)
  user    User                @relation(fields: [userId], references: [id])

  @@unique([userId, type, channel])
}

model AuditLog {
  id             BigInt        @id @default(autoincrement())
  actorId        Int?
  actorRole      Role?
  actorEmail     String?
  entityType     String
  entityId       String?
  action         String
  severity       AuditSeverity
  source         AuditSource
  description    String?
  oldValue       Json?
  newValue       Json?
  diff           Json?
  metadata       Json?
  occurredAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  retentionUntil DateTime?
  isSensitive    Boolean       @default(false)
  requestId      String?
  sessionId      String?
  traceId        String?

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([severity])
  @@index([occurredAt])
}

model AuditOutbox {
  id          BigInt            @id @default(autoincrement())
  payload     Json
  status      AuditOutboxStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?
  createdAt   DateTime          @default(now())
  processedAt DateTime?

  @@index([status])
}

/// Outbox Event for Cart and System Events
model OutboxEvent {
  id        String   @id @default(uuid())
  eventType String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([processed])
  @@index([createdAt])
}

/// System Settings for Feature Flags, Integrations, and Security
model Settings {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  value       Json
  category    SettingsCategory
  description String?
  updatedAt   DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@index([category])
  @@index([key])
}

enum SettingsCategory {
  FEATURE
  INTEGRATION
  SECURITY
  SYSTEM
}

