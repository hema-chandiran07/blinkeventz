{
  "name": "nearzro-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --config ./test/jest-unit.json --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "npm run test:db:migrate && jest --config ./test/jest-integration.json",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run test:unit -- --ci --coverage --passWithNoTests",
    "test:db:create": "node -e \"const {Client} = require('pg'); const c = new Client({host:'localhost', user:'postgres', password:'2006', database:'postgres'}); c.connect().then(() => c.query('CREATE DATABASE nearzro_test')).then(() => c.end()).catch(() => c.end())\"",
    "test:db:migrate": "cross-env DATABASE_URL=\"postgresql://postgres:2006@localhost:5432/nearzro_test\" npx prisma migrate deploy",
    "test:db:push": "cross-env DATABASE_URL=\"postgresql://postgres:2006@localhost:5432/nearzro_test\" npx prisma db push --skip-generate --force-reset --accept-data-loss",
    "test:db:reset": "cross-env DATABASE_URL=\"postgresql://postgres:2006@localhost:5432/nearzro_test\" npx prisma migrate reset --force --skip-seed",
    "test:db:setup": "npm run test:db:create && npm run test:db:push"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "~3.1000.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.3.8",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "~11.0.5",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^6.10.1",
    "@sendgrid/mail": "^8.1.6",
    "@types/nodemailer": "^7.0.11",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.6.0",
    "ioredis": "^5.9.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "~9.0.3",
    "lodash": "^4.17.23",
    "multer": "~2.0.2",
    "nodemailer": "^8.0.3",
    "openai": "^6.16.0",
    "passport": "~0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "~2.0.0",
    "passport-jwt": "^4.0.1",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.3.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^30.0.0",
    "@types/multer": "~2.0.0",
    "@types/node": "^20.11.30",
    "@types/passport-google-oauth20": "~2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/twilio": "^3.19.2",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "pg": "^8.20.0",
    "prisma": "6.10.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
