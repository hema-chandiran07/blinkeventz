generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model User {
  id                      Int                      @id @default(autoincrement())
  name                    String
  email                   String?                  @unique
  phone                   String?                  @unique
  passwordHash            String?
  googleId                String?                  @unique
  facebookId              String?                  @unique
  role                    Role                     @default(CUSTOMER)
  isActive                Boolean                  @default(true)
  isEmailVerified         Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  passwordResetExpiry     DateTime?
  passwordResetToken      String?
  AIPlan                  AIPlan[]
  bankAccounts            BankAccount[]
  bookings                Booking[]
  Cart                    Cart[]
  customerProfile         CustomerProfile?
  managedEvents           Event[]                  @relation("ManagedEvents")
  customerEvents          Event[]                  @relation("CustomerEvents")
  Event                   Event[]
  ExpressRequest          ExpressRequest[]
  KycDocument             KycDocument[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  payments                Payment[]
  vendor                  Vendor?
  venues                  Venue[]
}

model CustomerProfile {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  preferredCity String?
  notes         String?
  user          User    @relation(fields: [userId], references: [id])
}

model Vendor {
  id                 Int                      @id @default(autoincrement())
  userId             Int                      @unique
  businessName       String
  description        String?
  city               String
  area               String
  serviceRadiusKm    Int?
  verificationStatus VendorVerificationStatus @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  user               User                     @relation(fields: [userId], references: [id])
  services           VendorService[]
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model VendorService {
  id           Int                @id @default(autoincrement())
  vendorId     Int
  name         String
  serviceType  ServiceType
  pricingModel VendorPricingModel
  baseRate     Int
  minGuests    Int?
  maxGuests    Int?
  description  String?
  inclusions   String?
  exclusions   String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  cartItems    CartItem[]
  EventService EventService[]
  vendor       Vendor             @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

model Venue {
  id               Int                @id @default(autoincrement())
  ownerId          Int
  name             String
  type             VenueType
  description      String?
  address          String
  city             String
  area             String
  pincode          String
  capacityMin      Int
  capacityMax      Int
  basePriceMorning Int?
  basePriceEvening Int?
  basePriceFullDay Int?
  amenities        String?
  policies         String?
  status           VenueStatus        @default(PENDING_APPROVAL)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  availability     AvailabilitySlot[]
  events           Event[]
  EventService     EventService[]
  owner            User               @relation(fields: [ownerId], references: [id])
  photos           VenuePhoto[]
}

model VenuePhoto {
  id        Int      @id @default(autoincrement())
  venueId   Int
  url       String
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())
  venue     Venue    @relation(fields: [venueId], references: [id])
}

model AvailabilitySlot {
  id         Int        @id @default(autoincrement())
  entityType EntityType
  entityId   Int
  date       DateTime
  timeSlot   String
  status     SlotStatus @default(AVAILABLE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  venue      Venue      @relation(fields: [entityId], references: [id])
  bookings   Booking[]

  @@index([entityType, entityId, date, timeSlot])
}

model Booking {
  id        Int              @id @default(autoincrement())
  userId    Int
  slotId    Int
  createdAt DateTime         @default(now())
  slot      AvailabilitySlot @relation(fields: [slotId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  Payment   Payment[]
}

model CartItem {
  id              Int            @id @default(autoincrement())
  cartId          Int
  itemType        ItemType
  venueId         Int?
  vendorServiceId Int?
  addonId         Int?
  date            DateTime?
  timeSlot        String?
  quantity        Int            @default(1)
  unitPrice       Int
  totalPrice      Int
  meta            Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cart            Cart           @relation(fields: [cartId], references: [id])
  vendorService   VendorService? @relation(fields: [vendorServiceId], references: [id])

  @@index([cartId])
  @@index([vendorServiceId])
}

model AIPlan {
  id         Int          @id @default(autoincrement())
  userId     Int
  EventId    Int?
  budget     Int
  city       String
  area       String
  guestCount Int
  planJson   Json
  status     AIPlanStatus @default(GENERATED)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Event      Event?       @relation(fields: [EventId], references: [id])
  user       User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([EventId])
}

model Payment {
  id                Int             @id @default(autoincrement())
  userId            Int
  cartId            Int
  provider          PaymentProvider
  providerOrderId   String          @unique
  providerPaymentId String?
  signature         String?
  amount            Int
  currency          String          @default("INR")
  status            PaymentStatus
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  eventId           Int?
  cart              Cart            @relation(fields: [cartId], references: [id])
  Event             Event?          @relation(fields: [eventId], references: [id])
  user              User            @relation(fields: [userId], references: [id])

  @@index([cartId])
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model ExpressRequest {
  id         Int             @id @default(autoincrement())
  userId     Int
  EventId    Int             @unique
  planType   ExpressPlanType
  status     ExpressStatus   @default(PENDING)
  startedAt  DateTime
  expiresAt  DateTime
  expressFee Int
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  Event      Event           @relation(fields: [EventId], references: [id])
  user       User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

model KycDocument {
  id         Int        @id @default(autoincrement())
  userId     Int
  docType    KycDocType
  docNumber  String
  docFileUrl String
  status     KycStatus  @default(PENDING)
  verifiedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, status], map: "one_active_kyc_per_user")
  @@index([userId])
  @@index([status])
}

model BankAccount {
  id            Int      @id @default(autoincrement())
  userId        Int
  accountHolder String
  accountNumber String
  ifsc          String
  bankName      String
  branchName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isVerified    Boolean  @default(false)
  referenceId   String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isVerified])
}

model BankWebhookLog {
  id          Int      @id @default(autoincrement())
  referenceId String
  payload     Json
  status      String
  createdAt   DateTime @default(now())

  @@index([referenceId])
}

/// /////////////////////////////////
/// Event & EventServices
/// ////////////////////////////////
model Event {
  id                Int             @id @default(autoincrement())
  customerId        Int
  assignedManagerId Int?
  eventType         String
  title             String?
  date              DateTime
  timeSlot          String
  city              String
  area              String?
  venueId           Int?
  guestCount        Int
  status            EventStatus     @default(CONFIRMED)
  isExpress         Boolean         @default(false)
  subtotal          Int
  discount          Int             @default(0)
  platformFee       Int             @default(0)
  tax               Int             @default(0)
  totalAmount       Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  userId            Int?
  AIPlan            AIPlan[]
  assignedManager   User?           @relation("ManagedEvents", fields: [assignedManagerId], references: [id])
  customer          User            @relation("CustomerEvents", fields: [customerId], references: [id])
  User              User?           @relation(fields: [userId], references: [id])
  venue             Venue?          @relation(fields: [venueId], references: [id])
  services          EventService[]
  expressRequest    ExpressRequest?
  notifications     Notification[]
  payments          Payment[]
}

model EventService {
  id              Int                @id @default(autoincrement())
  eventId         Int
  itemType        ItemTypeForEvent
  venueId         Int?
  vendorServiceId Int?
  addonId         Int?
  serviceType     ServiceType?
  finalPrice      Int
  notes           String?
  status          EventServiceStatus @default(CONFIRMED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  event           Event              @relation(fields: [eventId], references: [id])
  vendorService   VendorService?     @relation(fields: [vendorServiceId], references: [id])
  venue           Venue?             @relation(fields: [venueId], references: [id])
}

model Notification {
  id                   Int                    @id @default(autoincrement())
  userId               Int
  eventId              Int?
  type                 NotificationType
  priority             NotificationPriority   @default(NORMAL)
  title                String
  message              String
  metadata             Json?
  read                 Boolean                @default(false)
  readAt               DateTime?
  status               NotificationStatus     @default(PENDING)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  event                Event?                 @relation(fields: [eventId], references: [id])
  user                 User                   @relation(fields: [userId], references: [id])
  NotificationDelivery NotificationDelivery[]

  @@index([userId, read])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model NotificationDelivery {
  id             Int                 @id @default(autoincrement())
  notificationId Int
  channel        NotificationChannel
  provider       String?
  status         DeliveryStatus      @default(PENDING)
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  providerRef    String?
  errorMessage   String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([channel, status])
}

model NotificationPreference {
  id      Int                 @id @default(autoincrement())
  userId  Int
  type    NotificationType
  channel NotificationChannel
  enabled Boolean             @default(true)
  user    User                @relation(fields: [userId], references: [id])

  @@unique([userId, type, channel])
}

model AuditLog {
  id             BigInt        @id @default(autoincrement())
  actorId        Int?
  actorRole      Role?
  actorEmail     String?
  entityType     String
  entityId       String?
  action         String
  severity       AuditSeverity
  source         AuditSource
  description    String?
  oldValue       Json?
  newValue       Json?
  diff           Json?
  metadata       Json?
  occurredAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  retentionUntil DateTime?
  isSensitive    Boolean       @default(false)
  requestId      String?
  sessionId      String?
  traceId        String?

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([severity])
  @@index([occurredAt])
}

model AuditOutbox {
  id          BigInt            @id @default(autoincrement())
  payload     Json
  status      AuditOutboxStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?
  createdAt   DateTime          @default(now())
  processedAt DateTime?

  @@index([status])
}

enum AuditSeverity {
  LOW
  INFO
  WARNING
  HIGH
  CRITICAL
}

enum AuditSource {
  USER
  SYSTEM
  ADMIN
  SERVICE
}

enum AuditOutboxStatus {
  PENDING
  PROCESSED
  FAILED
  DEAD_LETTER
}

enum Role {
  CUSTOMER
  VENDOR
  VENUE_OWNER
  ADMIN
  EVENT_MANAGER
  SUPPORT
}

enum VendorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ServiceType {
  CATERING
  DECOR
  PHOTOGRAPHY
  MAKEUP
  DJ
  MUSIC
  CAR_RENTAL
  PRIEST
  OTHER
}

enum VendorPricingModel {
  PER_EVENT
  PER_PERSON
  PER_DAY
  PACKAGE
}

enum CartStatus {
  ACTIVE
  LOCKED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ItemType {
  VENUE
  VENDOR_SERVICE
  ADDON
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
}

enum ExpressPlanType {
  FIXED
  CUSTOMIZED
}

enum ExpressStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

enum VenueType {
  HALL
  MANDAPAM
  LAWN
  RESORT
  BANQUET
}

enum VenueStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
  DELISTED
}

enum EntityType {
  VENUE
  VENDOR
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  HOLD
}

enum KycDocType {
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum AIPlanStatus {
  GENERATED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EventStatus {
  INQUIRY
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ItemTypeForEvent {
  VENUE
  VENDOR_SERVICE
  ADDON
}

enum EventServiceStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  VENDOR_APPROVED
  VENDOR_REJECTED
  VENUE_APPROVED
  VENUE_REJECTED
  SERVICE_APPROVED
  SERVICE_REJECTED
  EVENT_REMINDER
  EVENT_CANCELLED
  SYSTEM_ALERT
  OTHER
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  PARTIAL
  FAILED
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}
