version: "3.8"

services:
  # =====================================================
  # PostgreSQL Database
  # =====================================================
  postgres:
    image: postgres:15
    container_name: NearZro-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: 123
      POSTGRES_DB: NearZro
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - NearZro-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  # =====================================================
  # Redis Cache
  # =====================================================
  redis:
    image: redis:7-alpine
    container_name: NearZro-redis
    restart: unless-stopped
    ports:
      - "6379:6379"
    networks:
      - NearZro-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # =====================================================
  # Backend API (NestJS)
  # =====================================================
  api:
    build:
      context: ./NearZro-backend
      dockerfile: Dockerfile
    container_name: NearZro-api
    restart: unless-stopped
    env_file:
      - ./.env
    ports:
      - "3000:3000"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - NearZro-network
    volumes:
      - ./NearZro-backend:/app
      - /app/node_modules
    command: sh -c "npx prisma migrate deploy && npm run start:prod"

  # =====================================================
  # Frontend (Next.js)
  # =====================================================
  frontend:
    build:
      context: ./NearZro-frontend
      dockerfile: Dockerfile
    container_name: NearZro-frontend
    restart: unless-stopped
    ports:
      - "3001:3000"
    env_file:
      - ./NearZro-frontend/.env
    depends_on:
      - api
    networks:
      - NearZro-network
    environment:
      - NEXT_PUBLIC_API_URL=http://api:3000
      - NODE_ENV=production

volumes:
  postgres_data:

networks:
  NearZro-network:
    driver: bridge
