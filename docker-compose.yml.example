services:
  postgres:
    image: postgres:15
    container_name: nearzro-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      # Pulls from a .env file in the same directory as docker-compose.yml
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-2006}
      POSTGRES_DB: nearzro
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - nearzro-network
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U postgres" ]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: nearzro-redis
    restart: unless-stopped
    ports:
      - "6379:6379"
    networks:
      - nearzro-network
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 10s
      timeout: 5s
      retries: 5

  api:
    build:
      context: ./nearzro-backend
    container_name: nearzro-api
    env_file:
      - ./nearzro-backend/.env
    ports:
      - "3000:3000"
      - "5555:5555" # Open for manual Prisma Studio execution
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - nearzro-network
    restart: unless-stopped
    volumes:
      - ./nearzro-backend/uploads:/app/uploads
    # Executes migrations securely before starting the NestJS server
    command: sh -c "npx prisma migrate deploy && npm run start:prod"
    healthcheck:
      # Updated to hit the v1 global prefix
      test: [ "CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:3000/api/v1/health" ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  frontend:
    build:
      context: ./nearzro-frontend
      # Essential: Next.js needs this DURING the build phase to bake into the client-side JS
      args:
        NEXT_PUBLIC_API_URL: ${NEXT_PUBLIC_API_URL:-http://localhost:3000}
    container_name: nearzro-frontend
    env_file:
      - ./nearzro-frontend/.env
    ports:
      - "3001:3000"
    depends_on:
      api:
        # Ensures the frontend waits until backend migrations are done and the API is fully awake
        condition: service_healthy
    networks:
      - nearzro-network
    restart: unless-stopped
    environment:
      # Internal routing for SSR fetching
      API_INTERNAL_URL: http://nearzro-api:3000

volumes:
  postgres_data:

networks:
  nearzro-network:
