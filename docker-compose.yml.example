version: "3.8"

services:
  postgres:
    image: postgres:15
    container_name: blinkeventz-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: password
      POSTGRES_DB: blinkeventz
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

  redis:
    image: redis:7-alpine
    container_name: blinkeventz-redis
    restart: unless-stopped
    ports:
      - "6379:6379"

  api:
    build:
      context: ./blinkeventz-backend
      dockerfile: Dockerfile
    container_name: blinkeventz-api
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "3000:3000"
      - "5555:5555"
    depends_on:
      - postgres
      - redis
    volumes:
      - ./blinkeventz-backend:/app
      - /app/node_modules
    command: npm run start:dev

volumes:
  postgres_data:
