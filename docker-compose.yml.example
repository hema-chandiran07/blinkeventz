services:

  postgres:
    image: postgres:15
    container_name: nearzro-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: 2006
      POSTGRES_DB: nearzro
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - nearzro-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: nearzro-redis
    restart: unless-stopped
    ports:
      - "6379:6379"
    networks:
      - nearzro-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  api:
    build:
      context: ./nearzro-backend
    container_name: nearzro-api
    env_file:
      - ./nearzro-backend/.env
    ports:
      - "3000:3000"
      - "5555:5555"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - nearzro-network
    restart: unless-stopped
    command: sh -c "npx prisma migrate deploy && npm run start:prod"
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:3000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  frontend:
    build:
      context: ./nearzro-frontend
    container_name: nearzro-frontend
    env_file:
      - ./nearzro-frontend/.env
    ports:
      - "3001:3000"
    depends_on:
      - api
    networks:
      - nearzro-network
    restart: unless-stopped
    environment:
      NEXT_PUBLIC_API_URL: http://api:3000
      API_INTERNAL_URL: http://api:3000

volumes:
  postgres_data:

networks:
  nearzro-network:
