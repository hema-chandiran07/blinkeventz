# docker-compose.prod.yml  — PRODUCTION
# Usage: docker-compose -f docker-compose.prod.yml up --build -d

services:

  postgres:
    image: postgres:15-alpine
    container_name: nearzro-postgres
    restart: always
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - nearzro-network
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U ${POSTGRES_USER}" ]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    # No ports exposed — only accessible inside Docker network

  redis:
    image: redis:7-alpine
    container_name: nearzro-redis
    restart: always
    command: redis-server --requirepass ${REDIS_PASSWORD} --maxmemory 256mb --maxmemory-policy allkeys-lru
    volumes:
      - redis_data:/data
    networks:
      - nearzro-network
    healthcheck:
      test: [ "CMD", "redis-cli", "-a", "${REDIS_PASSWORD}", "ping" ]
      interval: 10s
      timeout: 5s
      retries: 5

  api:
    build:
      context: ./nearzro-backend
      target: runner
    container_name: nearzro-api
    env_file:
      - ./nearzro-backend/.env.production
    environment:
      NODE_ENV: production
      DATABASE_URL: "postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@nearzro-postgres:5432/${POSTGRES_DB}?connection_limit=50&pool_timeout=30&connect_timeout=15&statement_timeout=60000"
      REDIS_HOST: nearzro-redis
      REDIS_PORT: 6379
      FRONTEND_URL: ${FRONTEND_URL}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - nearzro-network
    restart: always
    volumes:
      - uploads_data:/app/uploads
    healthcheck:
      test: [ "CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:3000/health" ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    # No direct port exposure — nginx proxies to this

  frontend:
    build:
      context: ./nearzro-frontend
      target: runner
      args:
        NEXT_PUBLIC_API_URL: ${NEXT_PUBLIC_API_URL}
        NEXT_PUBLIC_RAZORPAY_KEY_ID: ${NEXT_PUBLIC_RAZORPAY_KEY_ID}
    container_name: nearzro-frontend
    environment:
      API_INTERNAL_URL: http://nearzro-api:3000
      NEXT_TELEMETRY_DISABLED: 1
      NODE_ENV: production
    depends_on:
      api:
        condition: service_healthy
    networks:
      - nearzro-network
    restart: always

  nginx:
    image: nginx:alpine
    container_name: nearzro-nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/nginx/ssl:ro # Mount your SSL certs here
    depends_on:
      - api
      - frontend
    networks:
      - nearzro-network
    restart: always

volumes:
  postgres_data:
  redis_data:
  uploads_data:

networks:
  nearzro-network:
    driver: bridge
