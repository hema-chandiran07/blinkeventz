# =====================================================
# Frontend Environment Variables (Example)
# Copy this file to .env and replace the values
# =====================================================

# Public API URL (used in browser requests)
# Example: http://localhost:3000 or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://your-api-url:3000

# Internal API URL (used inside Docker network)
# Example: http://api:3000
API_INTERNAL_URL=http://your-backend-service:3000

# Disable Next.js telemetry (0 = enabled, 1 = disabled)
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_SdeDiDMfA7Gt1y